<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <Color x:Key="WindowBgColor">#FF111827</Color>
    <Color x:Key="CardBgColor">#FF1F2937</Color>
    <Color x:Key="CardHoverColor">#FF374151</Color>
    <Color x:Key="TextColor">#FFF9FAFB</Color>
    <Color x:Key="MutedTextColor">#FF9CA3AF</Color>
    <Color x:Key="AccentColor">#FF6366F1</Color>
    <SolidColorBrush x:Key="WindowBgBrush" Color="{StaticResource WindowBgColor}" />
    <SolidColorBrush x:Key="CardBgBrush" Color="{StaticResource CardBgColor}" />
    <SolidColorBrush x:Key="CardHoverBrush" Color="{StaticResource CardHoverColor}" />
    <SolidColorBrush x:Key="TextBrush" Color="{StaticResource TextColor}" />
    <SolidColorBrush x:Key="MutedTextBrush" Color="{StaticResource MutedTextColor}" />
    <SolidColorBrush x:Key="AccentBrush" Color="{StaticResource AccentColor}" />
</ResourceDictionary>
