<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <Color x:Key="WindowBgColor">#FFF8FAFC</Color>
    <Color x:Key="CardBgColor">#FFFFFFFF</Color>
    <Color x:Key="CardHoverColor">#FFE5E7EB</Color>
    <Color x:Key="TextColor">#FF111827</Color>
    <Color x:Key="MutedTextColor">#FF6B7280</Color>
    <Color x:Key="AccentColor">#FF4F46E5</Color>
    <SolidColorBrush x:Key="WindowBgBrush" Color="{StaticResource WindowBgColor}" />
    <SolidColorBrush x:Key="CardBgBrush" Color="{StaticResource CardBgColor}" />
    <SolidColorBrush x:Key="CardHoverBrush" Color="{StaticResource CardHoverColor}" />
    <SolidColorBrush x:Key="TextBrush" Color="{StaticResource TextColor}" />
    <SolidColorBrush x:Key="MutedTextBrush" Color="{StaticResource MutedTextColor}" />
    <SolidColorBrush x:Key="AccentBrush" Color="{StaticResource AccentColor}" />
</ResourceDictionary>
