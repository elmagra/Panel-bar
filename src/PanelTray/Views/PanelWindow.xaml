<Window x:Class="PanelTray.Views.PanelWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:controls="clr-namespace:PanelTray.Views.Controls"
        Title="Mi Panel Tray"
        Width="{Binding Settings.PanelWidth}"
        Height="{Binding Settings.PanelHeight}"
        WindowStyle="None"
        ResizeMode="NoResize"
        AllowsTransparency="True"
        Background="Transparent"
        ShowInTaskbar="False"
        Topmost="True"
        AllowDrop="True"
        Deactivated="OnDeactivated"
        Closing="OnClosing">
    <Border Background="{DynamicResource WindowBgBrush}"
            CornerRadius="22"
            Padding="16">
        <Border.Effect>
            <DropShadowEffect BlurRadius="24" ShadowDepth="6" Opacity="0.35" />
        </Border.Effect>

        <Grid x:Name="RootGrid">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>

            <DockPanel>
                <Button Content="X"
                        Width="30"
                        Height="30"
                        Margin="4,0,0,0"
                        DockPanel.Dock="Right"
                        ToolTip="Ocultar panel (sigue en segundo plano)"
                        Style="{StaticResource SecondaryButtonStyle}"
                        Click="OnHidePanelClick" />
                <Button Content="+ App"
                        MinWidth="64"
                        Height="30"
                        Margin="4,0,0,0"
                        DockPanel.Dock="Right"
                        ToolTip="Anadir desde apps instaladas (Store, accesos directos...)"
                        Style="{StaticResource SecondaryButtonStyle}"
                        Click="OnAddInstalledAppClick" />
                <ToggleButton Width="30"
                              Height="30"
                              Margin="4,0,0,0"
                              DockPanel.Dock="Right"
                              ToolTip="Modo edicion: arrastra tarjetas o suelta accesos directos aqui"
                              IsChecked="{Binding EditMode, Mode=TwoWay}"
                              Style="{StaticResource EditToggleButtonStyle}">
                    <TextBlock Text="⋮⋮" FontSize="14" FontWeight="Bold" />
                </ToggleButton>
                <TextBlock Text="Mi Panel"
                           FontSize="18"
                           FontWeight="SemiBold"
                           VerticalAlignment="Center"
                           DockPanel.Dock="Left" />
            </DockPanel>

            <StackPanel Grid.Row="1" Margin="0,14,0,12">
                <DockPanel Margin="4,0,4,12">
                    <TextBlock Text="Hotkey"
                               Foreground="{DynamicResource MutedTextBrush}"
                               VerticalAlignment="Center"
                               Margin="0,0,8,0" />
                    <controls:HotkeyCaptureBox HotkeyText="{Binding HotkeyText, Mode=TwoWay}" />
                </DockPanel>

                <ItemsControl ItemsSource="{Binding Categories}">
                    <ItemsControl.ItemsPanel>
                        <ItemsPanelTemplate>
                            <StackPanel Orientation="Horizontal" />
                        </ItemsPanelTemplate>
                    </ItemsControl.ItemsPanel>
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <RadioButton Style="{StaticResource CategoryButtonStyle}"
                                         Content="{Binding}"
                                         GroupName="Categories"
                                         IsChecked="False"
                                         Checked="OnCategoryChecked" />
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>

                <ScrollViewer Margin="0,16,0,0" VerticalScrollBarVisibility="Auto">
                    <ItemsControl x:Name="AppsItems"
                                  ItemsSource="{Binding DisplayApps}">
                        <ItemsControl.ItemsPanel>
                            <ItemsPanelTemplate>
                                <WrapPanel />
                            </ItemsPanelTemplate>
                        </ItemsControl.ItemsPanel>
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <controls:AppCard />
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </ScrollViewer>
            </StackPanel>

            <Button Grid.Row="2"
                    Content="Configuracion"
                    Style="{StaticResource PrimaryButtonStyle}"
                    HorizontalAlignment="Stretch"
                    Click="OnSettingsClick" />

            <Canvas x:Name="DragOverlay"
                    Grid.RowSpan="3"
                    IsHitTestVisible="False"
                    HorizontalAlignment="Stretch"
                    VerticalAlignment="Stretch" />
        </Grid>
    </Border>
</Window>
