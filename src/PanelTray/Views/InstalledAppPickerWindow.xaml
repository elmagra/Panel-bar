<Window x:Class="PanelTray.Views.InstalledAppPickerWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Anadir desde apps instaladas"
        Width="640"
        Height="520"
        MinWidth="520"
        MinHeight="420"
        WindowStartupLocation="CenterOwner"
        ResizeMode="CanResizeWithGrip"
        Background="{DynamicResource WindowBgBrush}">
    <Grid Margin="18">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <TextBlock Text="Elegir aplicacion instalada"
                   FontSize="20"
                   FontWeight="SemiBold" />

        <TextBox Grid.Row="1"
                 Margin="0,12,0,10"
                 Padding="10,8"
                 Text="{Binding SearchText, UpdateSourceTrigger=PropertyChanged}"
                 ToolTip="Buscar por nombre" />

        <Border Grid.Row="2"
                Background="{DynamicResource CardBgBrush}"
                CornerRadius="14"
                Padding="8">
            <Grid>
                <ListBox ItemsSource="{Binding FilteredApps}"
                         SelectedItem="{Binding SelectedApp, Mode=TwoWay}"
                         Background="Transparent"
                         BorderThickness="0"
                         MouseDoubleClick="OnListDoubleClick">
                    <ListBox.ItemTemplate>
                        <DataTemplate>
                            <StackPanel Margin="4,6">
                                <TextBlock Text="{Binding DisplayName}" FontWeight="SemiBold" />
                                <TextBlock Text="{Binding SourceLabel}"
                                           Foreground="{DynamicResource MutedTextBrush}"
                                           FontSize="12" />
                                <TextBlock Text="{Binding Detail}"
                                           Foreground="{DynamicResource MutedTextBrush}"
                                           FontSize="11"
                                           TextTrimming="CharacterEllipsis" />
                            </StackPanel>
                        </DataTemplate>
                    </ListBox.ItemTemplate>
                </ListBox>

                <TextBlock Text="{Binding StatusText}"
                           HorizontalAlignment="Center"
                           VerticalAlignment="Center"
                           Foreground="{DynamicResource MutedTextBrush}"
                           TextWrapping="Wrap"
                           TextAlignment="Center"
                           Margin="16"
                           Visibility="{Binding IsLoading, Converter={StaticResource BoolToVisibilityConverter}}" />
            </Grid>
        </Border>

        <TextBlock Grid.Row="3"
                   Text="{Binding StatusText}"
                   Margin="0,10,0,0"
                   Foreground="{DynamicResource MutedTextBrush}"
                   FontSize="12" />

        <StackPanel Grid.Row="4"
                    Orientation="Horizontal"
                    HorizontalAlignment="Right"
                    Margin="0,14,0,0">
            <Button Content="Cancelar"
                    Width="110"
                    Margin="0,0,8,0"
                    Style="{StaticResource SecondaryButtonStyle}"
                    IsCancel="True" />
            <Button Content="Anadir"
                    Width="110"
                    Command="{Binding AddCommand}"
                    Style="{StaticResource PrimaryButtonStyle}"
                    Click="OnAddClick"
                    IsDefault="True" />
        </StackPanel>
    </Grid>
</Window>
