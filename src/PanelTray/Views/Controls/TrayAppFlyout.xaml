<UserControl x:Class="PanelTray.Views.Controls.TrayAppFlyout"

             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"

             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"

             MinWidth="260"

             Background="{DynamicResource WindowBgBrush}"

             Foreground="{DynamicResource TextBrush}">

    <Border Background="{DynamicResource WindowBgBrush}"

            BorderBrush="{DynamicResource CardHoverBrush}"

            BorderThickness="1"

            CornerRadius="8"

            Padding="4">

        <StackPanel>

            <StackPanel Margin="10,8,10,6">

                <TextBlock Text="Tailscale"

                           FontWeight="SemiBold"

                           FontSize="13"

                           Foreground="{DynamicResource TextBrush}" />

                <TextBlock Text="{Binding Snapshot.StateText, RelativeSource={RelativeSource AncestorType=UserControl}}"

                           FontSize="12"

                           Foreground="{DynamicResource MutedTextBrush}"

                           Margin="0,2,0,0" />

            </StackPanel>



            <TextBlock Margin="10,0,10,6"

                       FontSize="12"

                       Foreground="{DynamicResource TextBrush}"

                       Text="{Binding Snapshot.AccountName, RelativeSource={RelativeSource AncestorType=UserControl}}"

                       TextTrimming="CharacterEllipsis">

                <TextBlock.Style>

                    <Style TargetType="TextBlock">

                        <Setter Property="Visibility" Value="Visible" />

                        <Setter Property="Foreground" Value="{DynamicResource TextBrush}" />

                        <Style.Triggers>

                            <Trigger Property="Text" Value="">

                                <Setter Property="Visibility" Value="Collapsed" />

                            </Trigger>

                        </Style.Triggers>

                    </Style>

                </TextBlock.Style>

            </TextBlock>



            <TextBlock Margin="10,0,10,8"

                       FontSize="12"

                       Foreground="{DynamicResource TextBrush}"

                       TextWrapping="Wrap">

                <Run Text="This device:" />

                <Run Text="{Binding Snapshot.HostName, RelativeSource={RelativeSource AncestorType=UserControl}, Mode=OneWay}" />

                <Run Text=" (" />

                <Run Text="{Binding Snapshot.PrimaryIp, RelativeSource={RelativeSource AncestorType=UserControl}, Mode=OneWay}" />

                <Run Text=")" />

            </TextBlock>



            <Separator Margin="4,0" Background="{DynamicResource CardHoverBrush}" />



            <Button Style="{StaticResource TrayFlyoutButtonStyle}"

                    Content="Network devices"

                    Click="OnNativeMenuClick" />

            <Button Style="{StaticResource TrayFlyoutButtonStyle}"

                    Content="Exit nodes"

                    Click="OnNativeMenuClick" />

            <Button Style="{StaticResource TrayFlyoutButtonStyle}"

                    Content="Preferences"

                    Click="OnNativeMenuClick" />



            <Separator Margin="4,0" Background="{DynamicResource CardHoverBrush}" />



            <Button Style="{StaticResource TrayFlyoutButtonStyle}"

                    Content="Abrir menú de Windows"

                    Click="OnNativeMenuClick" />

            <Button Style="{StaticResource TrayFlyoutButtonStyle}"

                    Content="Desconectar"

                    Click="OnDisconnectClick" />

            <Button Style="{StaticResource TrayFlyoutButtonStyle}"

                    Content="About..."

                    Click="OnAboutClick" />

            <Button Style="{StaticResource TrayFlyoutButtonStyle}"

                    Content="Exit"

                    Click="OnExitClick" />

        </StackPanel>

    </Border>

</UserControl>

