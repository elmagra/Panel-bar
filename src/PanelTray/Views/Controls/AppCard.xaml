<UserControl x:Class="PanelTray.Views.Controls.AppCard"

             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"

             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"

             xmlns:controls="clr-namespace:PanelTray.Views.Controls"

             Width="{Binding CardWidth}"

             MinWidth="{Binding CardWidth}"

             MaxWidth="{Binding CardWidth}"

             MouseEnter="OnCardMouseEnter"

             MouseLeave="OnCardMouseLeave">

    <UserControl.Style>

        <Style TargetType="UserControl">

            <Style.Triggers>

                <DataTrigger Binding="{Binding IsEditMode}" Value="True">

                    <Setter Property="Cursor" Value="SizeAll" />

                </DataTrigger>

                <DataTrigger Binding="{Binding IsDropSlot}" Value="True">

                    <Setter Property="Cursor" Value="Arrow" />

                </DataTrigger>

            </Style.Triggers>

        </Style>

    </UserControl.Style>



    <Grid>

        <Border x:Name="CardBorder"

                Margin="4"

                Padding="6"

                CornerRadius="14"

                Background="{DynamicResource CardBgBrush}"

                ContextMenuOpening="OnContextMenuOpening">

            <Border.Style>

                <Style TargetType="Border">

                    <Setter Property="BorderThickness" Value="1" />

                    <Setter Property="BorderBrush" Value="Transparent" />

                    <Setter Property="Opacity" Value="1" />

                    <Style.Triggers>

                        <DataTrigger Binding="{Binding IsDropSlot}" Value="True">

                            <Setter Property="BorderBrush" Value="{DynamicResource AccentBrush}" />

                            <Setter Property="BorderThickness" Value="2" />

                            <Setter Property="Background" Value="Transparent" />

                            <Setter Property="Opacity" Value="0.55" />

                            <Setter Property="ContextMenu" Value="{x:Null}" />

                        </DataTrigger>

                        <DataTrigger Binding="{Binding IsEditMode}" Value="True">

                            <Setter Property="BorderBrush" Value="{DynamicResource AccentBrush}" />

                            <Setter Property="BorderThickness" Value="1.5" />

                            <Setter Property="Background" Value="{DynamicResource CardHoverBrush}" />

                        </DataTrigger>

                        <DataTrigger Binding="{Binding IsDragPlaceholder}" Value="True">

                            <Setter Property="Opacity" Value="0.2" />

                        </DataTrigger>

                    </Style.Triggers>

                </Style>

            </Border.Style>



            <Border.ContextMenu>

                <ContextMenu Style="{StaticResource AppContextMenuStyle}"
                             Background="{DynamicResource CardBgBrush}"
                             Foreground="{DynamicResource TextBrush}">

                    <ContextMenu.Resources>

                        <Style TargetType="MenuItem" BasedOn="{StaticResource AppMenuItemStyle}" />

                        <Style TargetType="Separator" BasedOn="{StaticResource AppMenuSeparatorStyle}" />

                    </ContextMenu.Resources>

                    <MenuItem Header="Abrir" Click="OnOpenClick" />

                    <MenuItem Header="Informacion" Click="OnInfoClick" />

                    <MenuItem Header="Cerrar" Click="OnCloseClick" ToolTip="Cierra la ventana de la app" />

                    <MenuItem Header="Cerrar total" Click="OnCloseAllClick" ToolTip="Cierra todos los procesos de la app" />

                    <MenuItem Header="Reiniciar app" Click="OnRestartClick" />

                    <Separator />

                    <MenuItem Header="Abrir ubicacion" Click="OnOpenLocationClick" />

                    <MenuItem Header="Editar" Click="OnEditClick" />

                    <MenuItem Header="Eliminar" Click="OnDeleteClick" />

                </ContextMenu>

            </Border.ContextMenu>



            <Grid>

                <Grid.RowDefinitions>

                    <RowDefinition Height="Auto" />

                    <RowDefinition Height="Auto" />

                    <RowDefinition Height="Auto" />

                </Grid.RowDefinitions>



                <TextBlock Grid.Row="0"

                           Text="⋮⋮"

                           FontSize="10"

                           HorizontalAlignment="Center"

                           Foreground="{DynamicResource MutedTextBrush}"

                           Margin="0,0,0,2"

                           Visibility="{Binding IsEditMode, Converter={StaticResource BoolToVisibilityConverter}}">

                    <TextBlock.Style>

                        <Style TargetType="TextBlock">

                            <Style.Triggers>

                                <DataTrigger Binding="{Binding IsDropSlot}" Value="True">

                                    <Setter Property="Visibility" Value="Collapsed" />

                                </DataTrigger>

                            </Style.Triggers>

                        </Style>

                    </TextBlock.Style>

                </TextBlock>



                <Rectangle Panel.ZIndex="2"

                           IsHitTestVisible="False"

                           RadiusX="12"

                           RadiusY="12"

                           Stroke="{DynamicResource AccentBrush}"

                           StrokeThickness="2"

                           StrokeDashArray="4 3"

                           Fill="Transparent"

                           Visibility="{Binding IsDropSlot, Converter={StaticResource BoolToVisibilityConverter}}" />



                <Grid Grid.Row="1"

                      Width="{Binding IconSize}"

                      Height="{Binding IconSize}"

                      HorizontalAlignment="Center">

                    <Grid.Style>

                        <Style TargetType="Grid">

                            <Style.Triggers>

                                <DataTrigger Binding="{Binding IsDropSlot}" Value="True">

                                    <Setter Property="Visibility" Value="Collapsed" />

                                </DataTrigger>

                            </Style.Triggers>

                        </Style>

                    </Grid.Style>

                    <Image Source="{Binding Icon}"
                           Width="{Binding IconSize}"
                           Height="{Binding IconSize}"
                           Stretch="Uniform"
                           HorizontalAlignment="Center"
                           VerticalAlignment="Center" />

                    <Ellipse Width="9"

                             Height="9"

                             HorizontalAlignment="Right"

                             VerticalAlignment="Top"

                             Stroke="{DynamicResource CardBgBrush}"

                             StrokeThickness="2"

                             Fill="{Binding StatusBrush}"

                             ToolTip="{Binding StatusToolTip}" />

                </Grid>



                <TextBlock Grid.Row="2"

                           Text="{Binding DisplayName}"

                           FontSize="11"

                           Margin="0,6,0,0"

                           MaxWidth="{Binding IconSize}"

                           TextAlignment="Center"

                           TextTrimming="CharacterEllipsis"

                           TextWrapping="NoWrap"

                           Visibility="{Binding ShowName, Converter={StaticResource BoolToVisibilityConverter}}" />

            </Grid>

        </Border>



        <Popup x:Name="TrayFlyoutPopup"

               Placement="Right"

               PlacementTarget="{Binding ElementName=CardBorder}"

               StaysOpen="True"

               AllowsTransparency="False"

               PopupAnimation="Fade"

               HorizontalOffset="8">

            <controls:TrayAppFlyout x:Name="TrayFlyout"

                                    NativeMenuRequested="OnTrayFlyoutNativeMenuRequested"

                                    ExitRequested="OnTrayFlyoutExitRequested"

                                    MouseEnter="OnFlyoutMouseEnter"

                                    MouseLeave="OnFlyoutMouseLeave" />

        </Popup>

    </Grid>

</UserControl>


